{
  "name": "iface",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:ai": "bun scripts/checkAI.ts",
    "check:backup": "bun scripts/checkBackup.ts",
    "check:docs": "bun scripts/checkDocsAssets.ts",
    "check:external": "bun scripts/checkExternalServices.ts",
    "check:external-records": "bun scripts/checkExternalSmokeRecords.ts",
    "smoke:external:ai": "bun run check:external -- --ai --record docs/external-ai-smoke-result.json",
    "smoke:external:gist": "bun run check:external -- --gist --record docs/external-gist-smoke-result.json",
    "check:pwa": "bun scripts/checkPWAAssets.ts",
    "check:quality-gate": "bun scripts/checkQualityGate.ts",
    "check:questions": "bun scripts/checkQuestions.ts",
    "check:release": "bun scripts/checkReleaseReadiness.ts",
    "check:sync": "bun scripts/checkGistSync.ts",
    "check:version": "bun scripts/checkVersionSync.ts",
    "check:all": "bun run check && bun run check:version && bun run check:release && bun run check:quality-gate && bun run check:docs && bun run check:external-records && bun run check:backup && bun run check:questions && bun run check:sync && bun run check:ai && bun run build && bun run check:pwa"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
